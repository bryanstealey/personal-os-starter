#!/usr/bin/env bash
# System Health Check
# Reads heartbeat files from ~/.{{systemName}}-health/ and reports stale
# components. Called by the morning ritual as its first step.
#
# Only components that actually write a heartbeat are listed here. As you
# wire up more automations, add a line to COMPONENTS — and make sure that
# automation writes `date +%s > "$HEARTBEAT_DIR/<name>"` when it succeeds.
# A component with no writer would report STALE forever and erode trust in
# the health check, so don't add one until its writer exists.
#
# Portable bash (works on Ubuntu/WSL bash 5 and macOS bash 3.2). No
# associative arrays so it runs everywhere the kit installs.

HEARTBEAT_DIR="$HOME/.{{systemName}}-health"
NOW=$(date +%s)
ISSUES=()

# Components: "name max_age_hours", one per line.
#   nightly-backup — written by ~/.local/bin/nightly-backup after each run
#   morning        — written by the /morning ritual at completion
#   shutdown       — written by the /shutdown ritual at completion
#   weekly         — written by the /weekly ritual at completion. It ships with
#                    no fixed schedule (the user sets their own cadence), so its
#                    max_age is generous — flag it only if it's gone quiet for
#                    well over a typical week, not on the first missed day.
# /midday is not shipped in this kit at all — there is no heartbeat to track
# until someone adds that ritual themselves. Add a line here (and a writer in
# the ritual) if you build it.
COMPONENTS="
nightly-backup 26
morning 36
shutdown 48
weekly 240
"

COMPONENT_COUNT=0
while read -r name max_hours; do
    [ -z "$name" ] && continue
    COMPONENT_COUNT=$((COMPONENT_COUNT + 1))
    max_seconds=$((max_hours * 3600))
    hb_file="$HEARTBEAT_DIR/$name"
    err_file="$HEARTBEAT_DIR/$name.error"

    # A component that ran but hit a problem writes an "<name>.error" file
    # (e.g. nightly-backup when the vault has no git remote). Surface it.
    if [ -f "$err_file" ]; then
        ISSUES+=("$name: ERROR ($(cat "$err_file"))")
        continue
    fi

    if [ ! -f "$hb_file" ]; then
        ISSUES+=("$name: NO HEARTBEAT (never ran or not yet wired)")
        continue
    fi

    last=$(cat "$hb_file")
    age=$((NOW - last))
    age_hours=$((age / 3600))

    if [ "$age" -gt "$max_seconds" ]; then
        ISSUES+=("$name: STALE (${age_hours}h ago, expected within ${max_hours}h)")
    fi
done <<EOF
$COMPONENTS
EOF

# Output
if [ ${#ISSUES[@]} -eq 0 ]; then
    echo "{\"status\": \"healthy\", \"components\": $COMPONENT_COUNT}"
else
    echo "{\"status\": \"issues\", \"count\": ${#ISSUES[@]}}"
    for issue in "${ISSUES[@]}"; do
        echo "  - $issue"
    done
fi
