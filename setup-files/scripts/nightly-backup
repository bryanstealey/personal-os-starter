#!/bin/bash
# Nightly backup: commit and push dirty git repos.
#
# Preferred scheduler on macOS is a launchd LaunchAgent (see the plist that
# SETUP.md installs at ~/Library/LaunchAgents). cron on macOS runs without
# your login environment and without Full Disk Access, so brew-installed git
# and gh are often invisible and pushes silently fail. launchd inherits a
# usable environment and is the supported path. (cron still works if you add
# a crontab entry, but you must grant cron Full Disk Access yourself.)
#
# Default scope is VAULT-ONLY. Backing up your other projects is opt-in:
# set BACKUP_PROJECTS=1 (and optionally PROJECT_DIRS) to also scan them.
#
# Configuration (env vars):
#   VAULT_DIR        — path to your vault. REQUIRED. No default; the script
#                      exits if it is unset so a typo never logs to a phantom
#                      path and silently backs up nothing.
#   BACKUP_PROJECTS  — set to 1 to also back up project repos (default: off).
#   PROJECT_DIRS     — space-separated dirs to scan when BACKUP_PROJECTS=1
#                      (default: ~/projects/).
#   SKIP_LIST        — array of repo names to skip (read-only clones, etc.).

# Apple Silicon brew lives in /opt/homebrew/bin; Intel brew in /usr/local/bin.
# Include both so git/gh resolve under launchd/cron's minimal PATH.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# Heartbeat directory for system-health monitoring.
HEARTBEAT_DIR="$HOME/.{{systemName}}-health"
mkdir -p "$HEARTBEAT_DIR"

# VAULT_DIR is required — no author-specific default.
VAULT_DIR="${VAULT_DIR:-}"
if [ -z "$VAULT_DIR" ]; then
  echo "ERROR: VAULT_DIR is not set. Set it in the LaunchAgent/crontab environment." >&2
  echo "$(date '+%Y-%m-%d %H:%M:%S') nightly-backup: VAULT_DIR not set" > "$HEARTBEAT_DIR/nightly-backup.error"
  exit 1
fi
# Normalize to a trailing slash so path joins below stay consistent.
case "$VAULT_DIR" in
  */) ;;
  *) VAULT_DIR="$VAULT_DIR/" ;;
esac

LOG="${VAULT_DIR}05-system/processing-logs/nightly-backup.log"
DATE=$(date +%Y-%m-%d)
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# Ensure log directory exists
mkdir -p "$(dirname "$LOG")"

echo "[$TIMESTAMP] Nightly backup starting" >> "$LOG"

# Build the list of directories to back up. Vault first, always.
BACKUP_DIRS=("${VAULT_DIR}")
if [ "${BACKUP_PROJECTS:-0}" = "1" ]; then
  PROJECT_DIRS="${PROJECT_DIRS:-$HOME/projects/}"
  for pdir in ${PROJECT_DIRS}*/; do
    [ -d "$pdir" ] && BACKUP_DIRS+=("$pdir")
  done
  echo "[$TIMESTAMP] BACKUP_PROJECTS=1: also scanning $PROJECT_DIRS" >> "$LOG"
fi

# Repos to skip — read-only clones or repos you don't own
SKIP_LIST=(
  # Add repo names here, e.g.:
  # "some-read-only-clone"
)

backed_up=0
skipped=0
failed=0
vault_has_remote=0

for dir in "${BACKUP_DIRS[@]}"; do
  [ -d "$dir/.git" ] || continue
  name=$(basename "$dir")

  # Is this the vault? (used for missing-remote heartbeat reporting)
  is_vault=0
  [ "$dir" = "${VAULT_DIR}" ] && is_vault=1

  # Skip if in the explicit skip list
  if [[ " ${SKIP_LIST[*]} " == *" $name "* ]]; then
    echo "[$TIMESTAMP] $name: skipped (in skip list)" >> "$LOG"
    skipped=$((skipped + 1))
    continue
  fi

  # Skip if no remote configured
  if ! git -C "$dir" remote get-url origin &>/dev/null; then
    echo "[$TIMESTAMP] $name: skipped (no remote)" >> "$LOG"
    skipped=$((skipped + 1))
    continue
  fi

  [ "$is_vault" -eq 1 ] && vault_has_remote=1

  # Resolve the actual branch name
  branch=$(git -C "$dir" symbolic-ref --short HEAD 2>/dev/null)
  if [ -z "$branch" ]; then
    echo "[$TIMESTAMP] $name: skipped (detached HEAD)" >> "$LOG"
    skipped=$((skipped + 1))
    continue
  fi

  # Fetch remote to detect divergence
  git -C "$dir" fetch origin 2>>"$LOG"

  # Check for dirty files (uncommitted changes)
  dirty=$(git -C "$dir" status --short 2>/dev/null | wc -l | tr -d ' ')
  if [ "$dirty" -eq 0 ]; then
    # Check for unpushed commits
    unpushed=$(git -C "$dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "0")
    if [ "$unpushed" -eq 0 ]; then
      skipped=$((skipped + 1))
      continue
    fi
    # Pull --rebase to reconcile any remote changes, then push
    if git -C "$dir" pull --rebase origin "$branch" 2>>"$LOG" && \
       git -C "$dir" push origin "$branch" 2>>"$LOG"; then
      echo "[$TIMESTAMP] $name: pushed $unpushed unpushed commits" >> "$LOG"
    else
      echo "[$TIMESTAMP] $name: push FAILED (unpushed only)" >> "$LOG"
      failed=$((failed + 1))
    fi
    backed_up=$((backed_up + 1))
    continue
  fi

  # Stage, commit, pull --rebase to reconcile, then push
  git -C "$dir" add -A 2>>"$LOG"
  git -C "$dir" commit -m "Nightly backup: $DATE" 2>>"$LOG"
  if git -C "$dir" pull --rebase origin "$branch" 2>>"$LOG" && \
     git -C "$dir" push origin "$branch" 2>>"$LOG"; then
    echo "[$TIMESTAMP] $name: committed $dirty files and pushed" >> "$LOG"
  else
    echo "[$TIMESTAMP] $name: FAILED" >> "$LOG"
    failed=$((failed + 1))
  fi
  backed_up=$((backed_up + 1))
done

echo "[$TIMESTAMP] Nightly backup complete: $backed_up backed up, $skipped skipped (clean or no remote), $failed FAILED" >> "$LOG"

# HONEST health signal: the success heartbeat is written ONLY when the vault has
# a remote AND zero repos failed to push. If any push fails — the classic cause is
# cron being unable to read the keychain credential, so `git push` silently 401s —
# we do NOT write a green heartbeat. system-health goes stale/red instead of
# reporting "backed up" over a broken backup. This is the bug that hides silent
# failures for weeks; do not "simplify" it back to counting attempts as successes.
if [ "$vault_has_remote" -eq 0 ]; then
  echo "[$TIMESTAMP] WARNING: vault has no git remote — nothing was pushed offsite" >> "$LOG"
  echo "$TIMESTAMP nightly-backup: vault ($VAULT_DIR) has no git 'origin' remote; offsite backup is not happening. Add a remote (GitHub opt-in) or rely on Obsidian Git + Time Machine." > "$HEARTBEAT_DIR/nightly-backup.error"
elif [ "$failed" -ne 0 ]; then
  echo "[$TIMESTAMP] WARNING: $failed repo(s) failed to push — NOT writing success heartbeat" >> "$LOG"
  echo "$TIMESTAMP nightly-backup: $failed repo(s) failed to push offsite; see $LOG. Common cause: cron can't read the keychain credential — use the launchd LaunchAgent (not cron) so git/gh can authenticate." > "$HEARTBEAT_DIR/nightly-backup.error"
else
  # All good — clear any prior error and write the success heartbeat.
  rm -f "$HEARTBEAT_DIR/nightly-backup.error"
  date +%s > "$HEARTBEAT_DIR/nightly-backup"
fi
